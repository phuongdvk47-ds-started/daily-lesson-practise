      {
        "id": 1,
        "task_type": "Word Ordering",
        "prompt": "Sắp xếp các từ sau thành câu hoàn chỉnh so sánh thành thị và nông thôn (dùng so sánh hơn):<br>countryside / the / is / quieter / than / the / city /.",
        "target_length": "1 sentence (5-7 words)",
        "focus_skill": "Word order with comparatives: subject + be + comparative + than + object.",
        "useful_language": [],
        "success_criteria": [
          "The sentence starts with 'The countryside'.",
          "The comparative adjective 'quieter' is used.",
          "The word 'than' links the two places.",
          "The sentence ends with 'the city.'"
