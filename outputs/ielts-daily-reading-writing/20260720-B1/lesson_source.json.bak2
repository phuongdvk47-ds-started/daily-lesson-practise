  "answers": {
    "reading_answers": [
      {
        "question_id": 1,
        "correct_answer": "TRUE",
        "question_type": "literal",
        "evidence_quote": "For example, Holywood is a suburban town of Belfast, and people who live there 'live in the suburbs'.",
        "evidence_paragraph": 1,
        "explanation_vi": "Đề bài dùng cách diễn đạt lại 'suburban town located near Belfast' (thị trấn ngoại ô nằm gần Belfast). So sánh với đoạn 1: 'Holywood is a suburban town of Belfast' — 'of Belfast' tức là thuộc về, tức là nằm gần Belfast. Hai vế nói cùng một sự thật, nên khẳng định là đúng (TRUE).",
        "why_others_wrong_vi": "Với dạng True/False/Not Given, ta không có phương án nhiễu A/B/C như trắc nghiệm. Ở đây cần phân biệt: câu không phải FALSE vì bài KHÔNG phủ nhận điều này; cũng không phải NOT GIVEN vì thông tin 'suburban town of Belfast' đã xuất hiện rõ ràng trong đoạn 1. Đáp án duy nhất hợp lệ là TRUE.",
        "depth_check_vi": "Câu hỏi ở mức độ 'literal' (thông tin nêu rõ), nhưng đòi hỏi người học nhận ra paraphrase 'located near' = 'of' thay vì chỉ tìm từ khóa y nguyên — tiêu chuẩn đọc hiểu B1 cơ bản.",
        "tip_vi": "Với dạng True/False/Not Given, hãy tìm BẰNG CHỨNG trực tiếp. Nếu bài nói đúng y như đề (dù dùng từ đồng nghĩa) → TRUE.",
        "stretch_note": ""
      },
      {
        "question_id": 2,
        "correct_answer": "FALSE",
        "question_type": "literal",
        "evidence_quote": "In the countryside there are fewer shops, no cinemas, and maybe only one bus a day.",
        "evidence_paragraph": 2,
        "explanation_vi": "Đề nói nông thôn 'có nhiều cửa hàng hơn thành phố' (more shops than cities). Nhưng đoạn 2 ghi rõ 'there are fewer shops' (ít cửa hàng hơn) ở nông thôn. 'Fewer' trái ngược hoàn toàn với 'more', nên phát biểu đi ngược bằng chứng → FALSE.",
        "why_others_wrong_vi": "Không phải NOT GIVEN vì số lượng cửa hàng đã được nêu cụ thể ('fewer shops'); không phải TRUE vì thông tin bị đảo ngược. Phát biểu sai so với bài nên chỉ có thể là FALSE.",
        "depth_check_vi": "Mức 'literal' nhưng có bẫy đảo ngược so sánh (reversed comparison) — học viên phải so sánh hướng của 'fewer' vs 'more', không chỉ lùng từ khóa 'shops'.",
        "tip_vi": "Cẩn thận với từ chỉ số lượng: 'fewer / less' (ít hơn) trái nghĩa với 'more' (nhiều hơn). Đảo ngược so sánh thường là FALSE.",
        "stretch_note": ""
      },
      {
        "question_id": 3,
        "correct_answer": "FALSE",
        "question_type": "literal",
        "evidence_quote": "In the countryside there are fewer shops, no cinemas, and maybe only one bus a day.",
        "evidence_paragraph": 2,
        "explanation_vi": "Đề khẳng định 'Mọi ngôi làng ở nông thôn đều có ít nhất một rạp chiếu phim' (every village... at least one cinema). Đoạn 2 lại nói rõ 'no cinemas' (không có rạp chiếu phim nào). 'Every village has' mâu thuẫn trực tiếp với 'no cinemas' → FALSE.",
        "why_others_wrong_vi": "Không phải TRUE vì bài phủ nhận sự tồn tại của rạp chiếu; không phải NOT GIVEN vì thông tin đã rõ ràng ('no cinemas'). Phát biểu sai nên là FALSE.",
        "depth_check_vi": "Mức 'literal' với bẫy khái quát hóa quá mức (over-generalised claim): dùng từ 'every' để gài bẫy, trong khi bài dùng 'no cinemas' phủ định toàn bộ.",
        "tip_vi": "Từ 'every / all / always' trong đề rất dễ là bẫy. Đối chiếu kỹ với bằng chứng có phủ định hay không.",
        "stretch_note": ""
      },
      {
        "question_id": 4,
        "correct_answer": "NOT GIVEN",
        "question_type": "classification",
        "evidence_quote": "because the quiet environment helps them feel calm and relaxed after a busy week.",
        "evidence_paragraph": 3,
