{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "execution-metadata.schema.json",
  "title": "Execution Metadata",
  "description": "Per-task execution metadata including engine, cost, tokens, and cache status.",
  "type": "object",
  "required": ["task_id", "stage", "execution_class", "engine", "created_at"],
  "properties": {
    "task_id": { "type": "string" },
    "stage": { "type": "string" },
    "execution_class": {
      "type": "string",
      "enum": ["DETERMINISTIC", "LOCAL_MODEL", "LOW_COST_LLM", "PREMIUM_LLM", "HUMAN_REQUIRED"]
    },
    "engine": { "type": "string" },
    "model": { "type": ["string", "null"] },
    "model_version": { "type": ["string", "null"] },
    "local": { "type": "boolean" },
    "prompt_version": { "type": ["string", "null"] },
    "input_hash": { "type": "string" },
    "output_hash": { "type": "string" },
    "input_tokens": { "type": "integer", "minimum": 0 },
    "output_tokens": { "type": "integer", "minimum": 0 },
    "estimated_cost": { "type": "number", "minimum": 0 },
    "latency_ms": { "type": "integer", "minimum": 0 },
    "cache_hit": { "type": "boolean" },
    "retry_count": { "type": "integer", "minimum": 0 },
    "escalated_from": { "type": ["string", "null"] },
    "escalation_reason": { "type": ["string", "null"] },
    "quality_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "validation_status": {
      "type": "string",
      "enum": ["PASS", "FAIL", "PENDING"]
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
